<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/floating_bg"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center_vertical">

        <!-- Кнопка Старт/Стоп: переключается между зелёным треугольником и красным квадратом -->
        <ImageButton
            android:id="@+id/btn_start"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_play"
            android:background="@null"
            android:padding="4dp"
            android:contentDescription="Старт/Стоп" />

        <!-- Кнопка Логи: серые три полоски -->
        <ImageButton
            android:id="@+id/btn_logs"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_logs"
            android:background="@null"
            android:padding="4dp"
            android:contentDescription="Логи" />

        <!-- Кнопка Закрыть: белый крестик -->
        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="@null"
            android:padding="4dp"
            android:contentDescription="Закрыть" />

    </LinearLayout>
</FrameLayout>
